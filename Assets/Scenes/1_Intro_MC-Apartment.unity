      value: 
      objectReference: {fileID: 344950014}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: dialogues.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: playerMovementScript
      value: 
      objectReference: {fileID: 94748045}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[0]'
      value: "There it is again. That restless rustling of papers... It\u2019s funny,
        isn't it?..."
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[1]'
      value: "Hearing how lively it sounds outside right now\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[2]'
      value: "People going about their lives, the world just... Moving\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[3]'
      value: "Heh!!\u2026 It\u2019s a bit of a sharp contrast to how I\u2019m feeling
        at the moment\u2026 No matter\u2026 I have to stay focused\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[4]'
      value: A professional doesn't let these things get in the way.
      objectReference: {fileID: 0}
    - target: {fileID: 4061478800764704104, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: m_Name
      value: Bedroom Dialogue
      objectReference: {fileID: 0}
