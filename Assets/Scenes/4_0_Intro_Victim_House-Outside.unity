    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: dialogueText
      value: 
      objectReference: {fileID: 1875963962}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: dialoguePanel
      value: 
      objectReference: {fileID: 1875963964}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: saveTriggered
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: continueButton
      value: 
      objectReference: {fileID: 1875963963}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: dialogues.Array.size
      value: 7
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: playerMovementScript
      value: 
      objectReference: {fileID: 1764362860}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[0]'
      value: ...Something about this place.
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[1]'
      value: 'The walls. The windows. The way the light hits the door. I''ve never
        been here before. So why does it feel like I have? '
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[2]'
      value: 'It''s unsettling. Cold. And yet... '
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[3]'
      value: ...there's something almost warm about it. Like a memory I can't quite
        reach.
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[4]'
      value: '*shakes his head*'
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[5]'
      value: 'Focus. This is a crime scene. '
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[6]'
      value: Nothing more.
      objectReference: {fileID: 0}
    - target: {fileID: 4061478800764704104, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: m_Name
      value: Victim's House Dialogue
      objectReference: {fileID: 0}
