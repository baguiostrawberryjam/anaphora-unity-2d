      objectReference: {fileID: 1693070272}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[0]'
      value: "Even with the broken walls and cracked flooring, the room is eerily
        'preserved,' with perfectly smooth sheets and a neat desk\u2026 The atmosphere
        here is kinda suffocating."
      objectReference: {fileID: 0}
    - target: {fileID: 3326163748004149210, guid: 963a1c2118d43c74daa6b5154d387951, type: 3}
      propertyPath: 'dialogues.Array.data[1]'
      value: "At this point, I can\u2019t start the investigation. I can only barely
        see around this darkness. There must be a light switch somewhere near here,
        right?"
      objectReference: {fileID: 0}
